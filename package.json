{
  "name": "kubepush",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "db:up": "docker compose up -d postgres",
    "db:generate": "pnpm --filter @kubepush/db db:generate",
    "db:migrate": "pnpm --filter @kubepush/db db:migrate",
    "db:push": "pnpm --filter @kubepush/db db:push",
    "db:studio": "pnpm --filter @kubepush/db db:studio"
  },
  "devDependencies": {
    "prettier": "^3",
    "turbo": "^2.9.16",
    "typescript": "^5"
  }
}
