{
  "name": "@korepush/operator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "build": "esbuild src/main.ts --bundle --platform=node --format=esm --outfile=dist/operator.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "dev": "tsx src/main.ts"
  },
  "dependencies": {
    "@korepush/k8s": "workspace:*",
    "@kubernetes/client-node": "^1.4.0"
  },
  "devDependencies": {
    "@korepush/eslint-config": "workspace:*",
    "@korepush/typescript-config": "workspace:*",
    "@types/node": "^22",
    "esbuild": "^0.25",
    "eslint": "^9",
    "tsx": "^4",
    "typescript": "^5"
  }
}
